{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/config",       "dest": "/api/config.js" },
    { "src": "/api/admin-create", "dest": "/api/admin-create.js" },
    { "src": "/admin",            "dest": "/admin.html" },
    { "src": "/admin.html",       "dest": "/admin.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",             "dest": "/index.html" }
  ]
}
